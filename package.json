{
  "name": "@realeye-io/realtesting-workspace",
  "private": true,
  "description": "Browser API emulation for fully automated end-to-end tests",
  "homepage": "https://github.com/RealEye-io/realtesting-open#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/RealEye-io/realtesting-open.git"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "assets:mediapipe": "node scripts/fetch-mediapipe-assets.mjs",
    "dev:face": "vite --config apps/face_detection_demo_app/vite.config.ts --port 4173 --strictPort",
    "dev:proxy": "vite --config apps/webcam_proxy_demo_app/vite.config.ts --port 4174 --strictPort",
    "dev:screen": "vite --config apps/screen_capture_demo_app/vite.config.ts --port 4175 --strictPort",
    "dev:features": "vite --config apps/browser_features_demo_app/vite.config.ts --port 4176 --strictPort",
    "dev:webrtc": "vite --config apps/webrtc_demo_app/vite.config.ts --port 4177 --strictPort",
    "dev:websocket": "vite --config apps/websocket_demo_app/vite.config.ts --port 4178 --strictPort",
    "build:screen-capture": "tsup packages/screen_capture/src/index.ts --format esm,cjs --dts --outDir packages/screen_capture/dist",
    "build:browser-features": "tsup packages/browser_features/src/index.ts --format esm,cjs --dts --outDir packages/browser_features/dist",
    "build:camera": "tsup packages/camera/src/index.ts --format esm,cjs --dts --outDir packages/camera/dist",
    "build:webrtc": "tsup packages/webrtc/src/index.ts --format esm,cjs --dts --outDir packages/webrtc/dist",
    "build:websocket": "tsup packages/websocket/src/index.ts --format esm,cjs --dts --outDir packages/websocket/dist",
    "build": "npm run build:screen-capture && npm run build:browser-features && npm run build:camera && npm run build:webrtc && npm run build:websocket",
    "verify:dist": "node scripts/verify-dist.mjs",
    "test:unit": "vitest run",
    "test:e2e": "npm run assets:mediapipe && playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@mediapipe/tasks-vision": "^0.10.32",
    "@playwright/test": "^1.50.1",
    "@types/node": "^20.11.30",
    "tsup": "^8.0.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.10",
    "vitest": "^1.6.0"
  }
}
